# ============================================
# Nmap Analyzer - Environment Variables
# ============================================
# Copy this file to .env and uncomment the lines
# for your AI provider. The analyzer.sh script
# auto-loads .env on startup.
#
#   cp .env_example .env
#
# ============================================

# --- Ollama (Local) ---
# Default provider. Runs locally, no API key needed.
# Only set this if Ollama is on a different host/port.
#OLLAMA_HOST=http://127.0.0.1:11434

# --- CAI Framework ---
# Used with: --ai alias1
#CAI_API_KEY=your-cai-api-key-here
#CAI_API_BASE=https://your-cai-endpoint/v1

# --- OpenAI ---
# Used with: --ai openai
#OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Claude (Anthropic) ---
# Used with: --ai claude
#ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
